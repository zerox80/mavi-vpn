# Log Level (info, debug, trace)
RUST_LOG=info

# Binding Address (UDP/QUIC)
# Binding Address (UDP/QUIC)
# Internally used by binary (set by docker-compose)
VPN_BIND_ADDR=0.0.0.0:10443

# Optional HTTP/2 CONNECT-IP listener over TLS/TCP.
# It may use the same numeric port as the UDP listener because the protocols differ.
# HTTP/2 is mutually exclusive with CR mode, HTTP/3 framing, and ECH.
# VPN_HTTP2_BIND_ADDR=0.0.0.0:10443

# Authentication Token (Required unless VPN_KEYCLOAK_ENABLED=true)
# Clients must match this token to connect. Never deploy with example/default values.
VPN_AUTH_TOKEN=

# Inner TUN MTU (bytes) pushed to clients.
# The outer QUIC payload MTU is derived automatically as VPN_MTU + 80.
# Valid range: 1280–1360. Default 1280 is safe on every network (IPv6 floor).
# VPN_MTU=1280

# Network Configuration (CIDR)
VPN_NETWORK=10.8.0.0/24

# IPv6 client subnet (ULA). Clients get internal fd00::/64 addresses and reach
# the internet via NAT66. Do NOT set this to your provider's public IPv6 prefix.
VPN_NETWORK_V6=fd00::/64

# IPv6 routing requires net.ipv6.conf.all.forwarding=1 on the HOST (the hardened,
# non-privileged container cannot write host sysctls). On RA-based clouds such as
# AWS Lightsail the WAN interface also needs accept_ra=2. See docs/INSTALLATION.md.
# Set VPN_DISABLE_IPV6=true to run IPv4-only (skips IPv6 setup and the wait below).
# VPN_DISABLE_IPV6=false
# Seconds to wait for the WAN's global IPv6 address to appear before continuing.
# VPN_IPV6_WAIT=30

# DNS Server to push to clients
VPN_DNS=1.1.1.1

# Censorship Resistant Mode (Layer 7 Obfuscation)
# If true, the server emulates a standard HTTP/3 web server to probes.
# Default: false
VPN_CENSORSHIP_RESISTANT=true

# Encrypted Client Hello (ECH) Options
# The outer SNI (cover name) sent on the wire to hide the real server.
# Common choices: cloudflare-ech.com, bing.com, etc.
# Default: cloudflare-ech.com
# VPN_ECH_PUBLIC_NAME=cloudflare-ech.com

# TCP MSS Clamping (Highly Recommended)
# Clamps TCP MSS to prevent fragmentation issues inside the tunnel.
# Default: true
VPN_MSS_CLAMPING=false

# (Optional) TUN Device Name
# VPN_TUN_DEVICE=tun0

# ------------------------------------------------------------------------------
# OPTIONAL: Traefik & Let's Encrypt Configuration
# Uncomment the line below to ENABLE Traefik.
# Leave it commented out to DISABLE Traefik (VPN Only).
# COMPOSE_PROFILES=traefik
# ------------------------------------------------------------------------------
# The domain name for your services (e.g., vpn.example.com)
#DOMAIN_NAME=example.com
# Email for Let's Encrypt notifications
#ACME_EMAIL=your-email@example.com

# Ports for Traefik
# ------------------------------------------------------------------------------
# CASE: STANDALONE (Traefik handles SSL)
# TRAEFIK_HTTP_PORT=80
# TRAEFIK_HTTPS_PORT=443

# CASE: BEHIND NGINX (Nginx handles SSL with Wildcard Cert)
# Set this to the port Nginx will proxy to (e.g. 11443)
#TRAEFIK_HTTP_PORT=11443
#TRAEFIK_HTTPS_PORT=11444 # Unused in 'No-SSL-Internal' mode but kept for completeness

# SSL Resolver Name
# - "myresolver" = Enable Traefik's internal Let's Encrypt ACME
# - "" (Empty)   = Disable Traefik ACME (Required if Nginx handles SSL)
#TRAEFIK_ACME_RESOLVER=

# ------------------------------------------------------------------------------
# OPTIONAL: Keycloak Authentication (OIDC)
# To enable Keycloak, uncomment the following TWO lines to load the Keycloak 
# compose file AND activate the required profiles.
# COMPOSE_FILE=docker-compose.yml:keycloak/docker-compose.yml
# COMPOSE_PROFILES=traefik,keycloak
# ------------------------------------------------------------------------------
# Set this to true in your actual .env to turn on JWT validation in the backend
VPN_KEYCLOAK_ENABLED=false

# Keycloak Server URL (must be reachable by the client)
# By default, the Keycloak container uses auth.${DOMAIN_NAME}
# VPN_KEYCLOAK_URL=https://auth.example.com

# Target Realm and Client ID used by the VPN clients
# VPN_KEYCLOAK_REALM=mavi-vpn
# VPN_KEYCLOAK_CLIENT_ID=mavi-client

# Optional fail-closed authorization policy. If set, accepted JWTs must contain
# the required realm/client role or OAuth scope.
# VPN_KEYCLOAK_REQUIRED_ROLE=vpn-user
# VPN_KEYCLOAK_REQUIRED_SCOPE=vpn:connect

# Database password for Keycloak Postgres. Required when Keycloak compose is enabled.
#KEYCLOAK_DB_PASSWORD=

# Keycloak initial admin credentials. KEYCLOAK_ADMIN_PASS is required when
# Keycloak compose is enabled.
#KEYCLOAK_ADMIN_USER=admin
#KEYCLOAK_ADMIN_PASS=
