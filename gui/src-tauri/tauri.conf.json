{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Mavi VPN",
  "identifier": "com.mavi.vpn",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mavi VPN",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Mavi VPN"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "rpm"],
    "windows": {
      "wix": {
        "fragmentPaths": ["wix/service.wxs"],
        "componentGroupRefs": ["CustomComponents"]
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/local/bin/mavi-vpn": "../../target/release/mavi-vpn",
          "/lib/systemd/system/mavi-vpn.service": "../../linux/mavi-vpn.service"
        },
        "postInstallScript": "linux/postinst",
        "preRemoveScript": "linux/prerm",
        "conflicts": ["mavi-vpn-cli"],
        "replaces": ["mavi-vpn-cli"]
      },
      "rpm": {
        "files": {
          "/usr/local/bin/mavi-vpn": "../../target/release/mavi-vpn",
          "/lib/systemd/system/mavi-vpn.service": "../../linux/mavi-vpn.service"
        },
        "conflicts": ["mavi-vpn-cli"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
