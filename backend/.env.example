# Log Level (info, debug, trace)
RUST_LOG=info

# Binding Address (WebTransport / UDP)
# Default WebTransport port is 4433.
VPN_BIND_ADDR=0.0.0.0:4433

# Binding Address (HTTP/2 Fallback / TCP)
# Use 443 to bypass restrictive firewalls (ensure no other web server is on this port)
VPN_BIND_ADDR_TCP=0.0.0.0:443

# Authentication Token (Required if Keycloak is disabled)
VPN_AUTH_TOKEN=change_me_to_secure_token

# Network Configuration (CIDR)
VPN_NETWORK=10.8.0.0/24

# DNS Server to push to clients
VPN_DNS=1.1.1.1

# Path to TLS certificates
# Option A: Practical for Let's Encrypt (requires mounting /etc/letsencrypt in docker-compose.yml)
VPN_CERT=/etc/letsencrypt/live/vpn.example.com/fullchain.pem
VPN_KEY=/etc/letsencrypt/live/vpn.example.com/privkey.pem

# TCP MSS Clamping
# Clamps TCP MSS to prevent fragmentation issues inside the tunnel.
VPN_MSS_CLAMPING=true

# (Optional) TUN Device Name
# VPN_TUN_DEVICE=tun0

# ------------------------------------------------------------------------------
# OPTIONAL: Traefik & Let's Encrypt Configuration
# Uncomment the line below to ENABLE Traefik.
# Leave it commented out to DISABLE Traefik (VPN Only).
# COMPOSE_PROFILES=traefik
# ------------------------------------------------------------------------------
# The domain name for your services (e.g., vpn.example.com)
DOMAIN_NAME=example.com
# Email for Let's Encrypt notifications
ACME_EMAIL=your-email@example.com

# Ports for Traefik
# ------------------------------------------------------------------------------
# CASE: STANDALONE (Traefik handles SSL)
# TRAEFIK_HTTP_PORT=80
# TRAEFIK_HTTPS_PORT=443

# CASE: BEHIND NGINX (Nginx handles SSL with Wildcard Cert)
# Set this to the port Nginx will proxy to (e.g. 11443)
TRAEFIK_HTTP_PORT=11443
TRAEFIK_HTTPS_PORT=11444 # Unused in 'No-SSL-Internal' mode but kept for completeness

# SSL Resolver Name
# - "myresolver" = Enable Traefik's internal Let's Encrypt ACME
# - "" (Empty)   = Disable Traefik ACME (Required if Nginx handles SSL)
TRAEFIK_ACME_RESOLVER=

# ------------------------------------------------------------------------------
# OPTIONAL: Keycloak Authentication (OIDC)
# To enable Keycloak, uncomment the following TWO lines to load the Keycloak 
# compose file AND activate the required profiles.
# COMPOSE_FILE=docker-compose.yml:keycloak/docker-compose.yml
# COMPOSE_PROFILES=traefik,keycloak
# ------------------------------------------------------------------------------
# Set this to true in your actual .env to turn on JWT validation in the backend
# KEYCLOAK_ENABLED=true

# Keycloak Server URL (must be reachable by the client)
# By default, the Keycloak container uses auth.${DOMAIN_NAME}
# KEYCLOAK_URL=https://auth.example.com

# Target Realm and Client ID used by the VPN clients
# KEYCLOAK_REALM=mavi-vpn
# KEYCLOAK_CLIENT_ID=mavi-client

# Database password for Keycloak Postgres
KEYCLOAK_DB_PASSWORD=mavi_keycloak_secret_change_me!123

# Keycloak Initial Admin credentials - CHANGE THESE!
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=mavi_admin_secure
